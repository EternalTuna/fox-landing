---
import identica1 from "../assets1/Identica.png";
import imgPattern from "../assets1/design.png";
import devImage from "../assets1/developing.png";
import meStatic from "../assets1/Me-static.png";
import meUndercover from "../assets1/Me-undercover.png";
import designerAvatar from "../assets1/photoCard.png";
import developerAvatar from "../assets1/devHero.png";
import sign from "../assets1/sign.svg";
import envelopeBase from "../assets1/envelope-base.png";
import designSkills from "../assets1/Frame 6.png";
import devSkills from "../assets1/Frame 7.png";
import festImage from "../assets1/fest.png";
import ladaImage from "../assets1/lada.png";
import bethanyImage from "../assets1/bethany.png";
import bethanySticker from "../assets1/bethany2.png";
import postcardsImage from "../assets1/postcards.png";
import postLetterImage from "../assets1/post-letter.png";
import loveInLetters1 from "../assets1/loveinletters1.png";
import loveInLetters2 from "../assets1/loveinletters2.png";
import loveInLetters3 from "../assets1/loveinletters3.png";
import mountainsImage from "../assets1/5mountains.png";
import noteImage from "../assets1/note1.png";
import lastochkaImage from "../assets1/lastochka.png";
import lastochkaImage1 from "../assets1/lastochka1.png";
import lastochkaImage2 from "../assets1/lastochka2.png";
import heart1Image from "../assets1/Heart1.png";
import heart3Image from "../assets1/Heart3.png";

const identityRows = [
  ["Брендинг ПрибойФест", "2025", "Айдентика события"],
  ["Каталог АвтоВаз", "2025", "Айдентика"],
  ["Брендинг BethanyBase", "2025", "Айдентика бренда"],
];

const identityImages = [festImage, ladaImage, bethanyImage];
const identityDescriptions = [
  "Визуальный стиль ПрибойФеста строиться на природных цветах прибрежья. Синий - море, желтый - небо во время заката, песочный - пляж. Весь визуал работает на то, чтобы посетители почувствовали себя в среде \"как рыбка в воде\", поэтому в продукт включены изображения самих морских обитателей. На браслетах изображен маленький парусник, мирно плывущий по волнам.",
  "Интерактивный каталог моделей АвтоВаз в стиле классической советской верстки. Элементы и цветовая гамма были подобраны на основе раритетных каталогов авто 1960 - 1970 годов выпуска.",
  "Полная разработка бренда. Начиная от позиции, заканчивая печатной продукцией и упаковкой. Конечным результатом был брендбук.",
];

const graphicRows = [
  ["Открытки весна", "2023", "Печатная продукция"],
  ["Любовь в мелочах и стихах", "2024", "Плакат"],
  ["Буклет Пятигорск", "2024", "Печатная продукция"],
  ["Дизайн тетради", "2025", "Печатная продукция"],
  ["Ласточка", "2025", "Иллюстрации для книги"],
  ["Меланхолия", "2026", "Плакат"],
];

const springDescription =
  "Милые открытки с векторными рисунками весенних растений, объединенные общей цветовой палитрой и стилем.";
const loveLettersDescription =
  "Идея создать серию плакатов возникла сразу когда наткнулась на подборку архивных фото. Хотелось соединить теплые запечатленные на пленку моменты с чувственными словами. И это сработало. Стихи русских писателей идеально дополняют фотографии советских пар.\n\nСерия плакатов заняла 1 место в конкурсе “Плакат молодых художников” в Мурманском областном художественном музее.";
const mountainsDescription =
  "Это фигурный буклет для туристического маршрута 6 - “Пятигорск Лермонтова”. В сложенном состоянии фигуры персонажей “Герой нашего времени” складываються в одну композицию.";
const noteDescription =
  "Я разработала этот дизайн тетради для своей бабушки. У нее есть привычка записывать информацию на разных листочках, а потом забывать куда записала. Поэтому я создала для нее тетрадку в клеточку, чтобы она ничего не теряла :)";
const lastochkaDescription =
  "Когда я прочитала “Ласточку”, то в голове сразу возникла метафора на материнство, и я решила изобразить историю именно так.";
const melancholyEmbedUrl =
  "https://embed.figma.com/proto/0LkhO4fS9qv5nrriaO9res/%D0%94%D0%B5%D0%B2%D1%83%D1%88%D0%BA%D0%B0-%D0%B8-%D0%BA%D0%BE%D1%81%D0%BC%D0%BE%D1%81?node-id=1-3&starting-point-node-id=1%3A3&embed-host=share";
const walletEmbedUrl =
  "https://embed.figma.com/design/7bIiZ5oqV5OitqWtFa7AP3/%D0%9A%D0%BE%D1%88%D0%B5%D0%BB%D0%B5%D1%87%D0%B5%D0%BA?node-id=0-1&embed-host=share";
const storageEmbedUrl =
  "https://embed.figma.com/design/iT7hQ2qok9o5VKYWX0Wjdl/Storage?node-id=0-1&embed-host=share";

const devRows = [
  ["Кошелечек", "2026", "Разработка B2C"],
  ["Storage", "2026", "Разработка B2B"],
];

const contactLetters = ["к", "о", "н", "т", "а", "к", "т", "ы"];
const contactCirclePositions = [
  "left-[366px] top-[-162px]",
  "left-[132px] top-[-176px]",
  "left-[252px] top-[-108px]",
  "left-[330px] top-[-58px]",
  "left-[412px] top-[-98px]",
  "left-[92px] top-[-108px]",
  "left-[478px] top-[-146px]",
  "left-[592px] top-[-104px]",
];
---

<main class="min-w-[1440px] bg-white pb-16 text-[#272727]">
  <div class="relative mx-auto h-[5274px] w-[1440px]">
    <div class="absolute left-[152px] top-[84px] z-30 flex h-[41px] w-[305px] items-end">
      <button
        id="name-toggle"
        type="button"
        class="display-font whitespace-nowrap bg-transparent text-[64px] leading-none text-[#6c6c6a] outline-none transition-all duration-300"
        aria-pressed="false"
      >
        Алиса Канапина
      </button>
    </div>
    <nav class="absolute left-[720px] top-[81px] z-20 flex w-[570px] items-center gap-[64px] text-[24px] font-medium leading-normal text-[#6c6c6a]">
      <a
        class="whitespace-nowrap rounded-full px-3 py-1 transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-[#272727]"
        href="#identity"
      >
        Айдентика
      </a>
      <a
        class="whitespace-nowrap rounded-full px-3 py-1 transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-[#272727]"
        href="#graphics"
      >
        Графика
      </a>
      <a
        class="whitespace-nowrap rounded-full px-3 py-1 transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-[#272727]"
        href="#dev"
      >
        UX/UI
      </a>
    </nav>

    <section class="absolute left-[150px] top-[152px] h-[672px] w-[1140px] overflow-hidden bg-gradient-to-b from-[#6c6c6a] to-[#d2d2ce]" data-fade>
      <img
        src={meUndercover.src}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-0"
        data-me-undercover
      />
      <img
        src={meStatic.src}
        alt=""
        class="absolute inset-0 z-10 h-full w-full object-cover opacity-95"
        data-me-static
      />
      <div
        class="pointer-events-none absolute inset-0 z-20"
        style="background-image:linear-gradient(to right, rgba(255,255,255,0.8) 1px, transparent 1px),linear-gradient(to bottom, rgba(255,255,255,0.8) 1px, transparent 1px);background-size:95px 96px;"
      ></div>
    </section>

    <section class="group absolute left-[160px] top-[942px] h-[430px] w-[601px] overflow-visible" data-fade>
      <div class="relative h-[372px] w-[601px] origin-top-left scale-95">
        <div class="absolute left-[31px] top-0 z-20 h-[372px] w-[570px] rounded-[20px] bg-[#e8ccd8] shadow-[0_10px_10px_rgba(0,0,0,0.25)]"></div>
        <div class="absolute left-0 top-[83px] z-30 h-[224px] w-[224px] rotate-[-4.66deg] overflow-hidden border-[10px] border-white shadow-[0_10px_10px_rgba(0,0,0,0.25)]">
          <img src={designerAvatar.src} alt="" class="h-full w-full object-cover" />
        </div>
        <div class="absolute left-[65px] top-[37px] z-30 text-[12px]">O.@ / Love You Partner Comp.</div>
        <div class="absolute left-[370px] top-[30px] z-30 flex h-[30px] w-[198px] items-center justify-center border border-black text-[16px]">NO. OA22ATK301469</div>
        <p class="display-font absolute left-[262px] top-[78px] z-30 w-[284px] text-right text-[40px] leading-none">Удостоверение дизайнера</p>
        <div class="absolute left-[275px] top-[150px] z-30 space-y-[14px] text-[12px] font-semibold">
          <p>ИМЯ <span class="font-normal">Алиса К.Р</span></p>
          <p>ДАТА РОЖДЕНИЯ <span class="font-normal">2005 - 06 - 28</span></p>
          <p>СПЕЦИАЛЬНОСТЬ <span class="font-normal">Дизайнер</span></p>
          <p>ДАТА ЛИЦЕНЗИИ <span class="font-normal">2023 - 09 - 03</span></p>
        </div>
        <div class="absolute left-[271px] top-[294px] z-30 h-[29px] w-[281px] bg-white text-[12px] leading-[29px]">
          <span class="ml-[10px]">Подпись</span>
        </div>
        <img src={sign.src} alt="" class="absolute left-[394px] top-[273px] z-30 h-[50px] w-[89px] -rotate-[6deg]" />
        <img
          src={designSkills.src}
          alt="Навыки дизайна"
          class="pointer-events-none absolute left-1/2 top-[248px] z-10 w-[400px] -translate-x-1/2 translate-y-0 opacity-0 transition-all duration-500 ease-out group-hover:translate-y-[80px] group-hover:opacity-100"
        />
      </div>
    </section>

    <section class="group absolute left-[688px] top-[1420px] h-[430px] w-[601px] overflow-visible" data-fade>
      <div class="relative h-[372px] w-[601px] origin-top-left scale-95">
        <div class="absolute left-[31px] top-0 z-20 h-[372px] w-[570px] rounded-[20px] bg-[#272727] shadow-[0_10px_10px_rgba(0,0,0,0.25)]"></div>
        <div class="absolute left-[-12px] top-[76px] z-30 h-[224px] w-[224px] rotate-[8deg] overflow-hidden border-[10px] border-white shadow-[0_10px_10px_rgba(0,0,0,0.25)]">
          <img src={developerAvatar.src} alt="" class="h-full w-full object-cover" />
        </div>
        <div class="absolute left-[65px] top-[37px] z-30 text-[12px] text-white">O.@ / Love You Partner Comp.</div>
        <div class="absolute left-[370px] top-[30px] z-30 flex h-[30px] w-[198px] items-center justify-center border border-white text-[16px] text-white">NO. OA77ATK901499</div>
        <p class="display-font absolute left-[232px] top-[78px] z-30 w-[331px] text-right text-[40px] leading-none text-[#e8ccd8]">Удостоверение разработчика</p>
        <div class="absolute left-[275px] top-[150px] z-30 space-y-[14px] text-[12px] font-semibold text-white">
          <p>ИМЯ <span class="font-normal">Алиса К.Р</span></p>
          <p>ДАТА РОЖДЕНИЯ <span class="font-normal">2005 - 06 - 28</span></p>
          <p>СПЕЦИАЛЬНОСТЬ <span class="font-normal">Frontend Developer</span></p>
          <p>ДАТА ЛИЦЕНЗИИ <span class="font-normal">2025 - 08 - 03</span></p>
        </div>
        <div class="absolute left-[271px] top-[294px] z-30 h-[29px] w-[281px] bg-white text-[12px] leading-[29px] text-black">
          <span class="ml-[10px]">Подпись</span>
        </div>
        <img src={sign.src} alt="" class="absolute left-[394px] top-[273px] z-30 h-[50px] w-[89px] -rotate-[6deg]" />
        <img
          src={devSkills.src}
          alt="Навыки разработки"
          class="pointer-events-none absolute left-1/2 top-[248px] z-10 w-[400px] -translate-x-1/2 translate-y-0 opacity-0 transition-all duration-500 ease-out group-hover:translate-y-[80px] group-hover:opacity-100"
        />
      </div>
    </section>

    <section class="absolute left-[836px] top-[985px] w-[345px] text-[#6c6c6a]" data-fade>
      <p class="display-font text-[40px]">ОБО МНЕ</p>
      <p class="mt-11 text-[12px] leading-normal">
        Привет! Я Алиса (≧◡≦) ♡
        <br /><br />
        Мой творческий псевдоним — Skygge.
        <br />
        Я графический дизайнер и frontend-разработчик из Санкт-Петербурга. Мне интересно развиваться на стыке дизайна и разработки: изучать новые инструменты, улучшать пользовательский опыт и превращать идеи в удобные цифровые продукты. Постоянно учусь, экспериментирую и стараюсь делать вещи, которые будут полезны людям (｡•̀ᴗ-)✧
      </p>
    </section>

    <section class="absolute left-[214px] top-[1421px] w-[347px] text-[#6c6c6a]" data-fade>
      <p class="display-font text-[40px]">ОБРАЗОВАНИЕ</p>
      <div class="mt-11 space-y-12">
        <div>
          <p class="text-[16px] font-medium">2023 - 2025</p>
          <p class="mt-2 text-[12px]">МТКС Графический дизайн (диплом с отличием)</p>
          <p class="text-[12px] text-[#e8ccd8]">+ призер конкурса Профмастерства</p>
        </div>
        <div>
          <p class="text-[16px] font-medium">2025</p>
          <p class="mt-2 w-[274px] text-[12px]">СПБГУТ им. Бонч-Бруевича Информационные системы и технологии</p>
        </div>
      </div>
    </section>

    <section id="identity" class="absolute left-[112px] top-[2021px] w-[1178px]" data-fade>
      <img src={identica1.src} alt="" class="absolute left-[394px] top-0 h-[293px] w-[784px] object-cover" />
      <div class="absolute left-0 top-[108px] w-[319px] text-right">
        <p class="display-font text-[96px] leading-none text-[#e8ccd8]">Айдентика</p>
        <p class="ml-auto mt-5 w-[218px] text-[12px] leading-normal">Проекты связанные с разработкой фирменного стиля и всего что связано с брендингом</p>
      </div>
      <div
        class="absolute left-[396px] top-[326px] w-[784px] border-y border-[#6c6c6a]"
        data-accordion-group="identity"
      >
        {
          identityRows.map(([name, year, type], index) => (
            <div
              class={`accordion-item ${index < identityRows.length - 1 ? "border-b border-[#6c6c6a]" : ""}`}
              data-accordion-item
            >
              <button
                type="button"
                class="accordion-trigger grid h-[66px] w-full grid-cols-[1fr_120px_1fr] items-center px-[27px] text-left text-[12px] text-[#272727] transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-white"
                aria-expanded="false"
                data-accordion-trigger
              >
                <span>{name}</span>
                <span>{year}</span>
                <span>{type}</span>
              </button>
              <div class="accordion-panel max-h-0 overflow-hidden bg-white transition-[max-height] duration-500 ease-in-out" data-accordion-panel>
                <div class="accordion-content-shell">
                  <div class="relative overflow-visible rounded-[10px]">
                    <img src={identityImages[index].src} alt={name} class="h-auto w-full object-contain" />
                    {
                      index === 2 && (
                        <img
                          src={bethanySticker.src}
                          alt="Bethany sticker"
                          class="absolute bottom-[-136px] left-[513px] h-[241px] w-[241px] rotate-[14.3deg] object-contain opacity-100"
                        />
                      )
                    }
                  </div>
                  <p class="accordion-text text-[12px] text-[#6c6c6a]">{identityDescriptions[index]}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="graphics" class="shiftable absolute left-[112px] top-[2676px] w-[1178px]" data-fade>
      <img src={imgPattern.src} alt="" class="absolute left-[399px] top-0 h-[293px] w-[775px] object-cover" />
      <div class="absolute left-0 top-[108px] w-[319px] text-right">
        <p class="display-font text-[96px] leading-none text-[#e8ccd8]">Графика</p>
        <p class="ml-auto mt-5 w-[218px] text-[12px] leading-normal">Плакаты, печатная продукция и личные проекты</p>
      </div>
      <div
        class="absolute left-[396px] top-[326px] w-[784px] border-y border-[#6c6c6a]"
        data-accordion-group="graphics"
      >
        {
          graphicRows.map(([name, year, type], index) => (
            <div
              class={`accordion-item ${index < graphicRows.length - 1 ? "border-b border-[#6c6c6a]" : ""}`}
              data-accordion-item
            >
              <button
                type="button"
                class="accordion-trigger grid h-[66px] w-full grid-cols-[1fr_120px_1fr] items-center px-[27px] text-left text-[12px] text-[#272727] transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-white"
                aria-expanded="false"
                data-accordion-trigger
              >
                <span>{name}</span>
                <span>{year}</span>
                <span>{type}</span>
              </button>
              <div class="accordion-panel max-h-0 overflow-hidden bg-white transition-[max-height] duration-500 ease-in-out" data-accordion-panel>
                {index === 0 ? (
                  <div class="accordion-content-shell">
                    <div class="flex items-start">
                      <img src={postcardsImage.src} alt="Открытки весна" class="w-[240px] object-contain" />
                      <div class="ml-[36px] flex flex-col">
                        <img src={postLetterImage.src} alt="Шаблон письма" class="w-[300px] object-contain" />
                        <p class="accordion-text max-w-[300px] text-[12px] text-[#6c6c6a]">
                          {springDescription}
                        </p>
                      </div>
                    </div>
                  </div>
                ) : index === 1 ? (
                  <div class="accordion-content-shell">
                    <div class="grid h-[334px] w-[728px] grid-cols-3 gap-[10px]">
                      <img src={loveInLetters1.src} alt="Плакат 1" class="h-full w-full object-contain" />
                      <img src={loveInLetters2.src} alt="Плакат 2" class="h-full w-full object-contain" />
                      <img src={loveInLetters3.src} alt="Плакат 3" class="h-full w-full object-contain" />
                    </div>
                    <p class="accordion-text whitespace-pre-line text-[12px] text-[#6c6c6a]">
                      {loveLettersDescription}
                    </p>
                  </div>
                ) : index === 2 ? (
                  <div class="accordion-content-shell">
                    <div class="flex items-start">
                      <img src={mountainsImage.src} alt="Буклет Пятигорск" class="w-[470px] object-contain" />
                      <p class="ml-[36px] w-[230px] text-[12px] leading-normal text-[#6c6c6a]">
                        {mountainsDescription}
                      </p>
                    </div>
                  </div>
                ) : index === 3 ? (
                  <div class="accordion-content-shell">
                    <img src={noteImage.src} alt="Дизайн тетради" class="w-full object-contain" />
                    <p class="accordion-text text-[12px] text-[#6c6c6a]">
                      {noteDescription}
                    </p>
                  </div>
                ) : index === 4 ? (
                  <div class="accordion-content-shell">
                    <img src={lastochkaImage.src} alt="Ласточка" class="w-full object-contain" />
                    <div class="mt-[32px] flex items-start">
                      <div class="grid w-[340px] grid-cols-2 gap-[10px]">
                        <img src={lastochkaImage1.src} alt="Ласточка деталь 1" class="w-full object-contain" />
                        <img src={lastochkaImage2.src} alt="Ласточка деталь 2" class="w-full object-contain" />
                      </div>
                      <p class="ml-[36px] w-[290px] text-[12px] leading-normal text-[#6c6c6a]">
                        {lastochkaDescription}
                      </p>
                    </div>
                  </div>
                ) : index === 5 ? (
                  <div class="accordion-content-shell">
                    <iframe
                      title="Меланхолия"
                      src={melancholyEmbedUrl}
                      class="h-[410px] w-[728px] border border-[rgba(0,0,0,0.1)]"
                      allowfullscreen
                    ></iframe>
                  </div>
                ) : (
                  <div class="accordion-content-shell">
                    <p class="text-[12px] text-[#6c6c6a]">Контент блока скоро добавим.</p>
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
      <img
        src={devImage.src}
        alt=""
        class="shiftable absolute left-[396px] top-[879px] h-[334px] w-[784px] object-cover"
        data-graphics-after-accordion
      />
    </section>

    <section id="dev" class="shiftable absolute left-[112px] top-[3718px] w-[1178px]" data-fade>
      <div class="absolute left-0 top-0 w-[319px] text-right">
        <p class="display-font text-[96px] leading-none text-[#e8ccd8]">Разработка</p>
        <p class="ml-auto mt-5 w-[218px] text-[12px] leading-normal">UX/UI дизайн, разработка интерфейсов, веб дизайн</p>
      </div>
      <div
        class="absolute left-[385px] top-[206px] w-[784px] border-y border-[#6c6c6a]"
        data-accordion-group="dev"
      >
        {
          devRows.map(([name, year, type], index) => (
            <div
              class={`accordion-item ${index < devRows.length - 1 ? "border-b border-[#6c6c6a]" : ""}`}
              data-accordion-item
            >
              <button
                type="button"
                class="accordion-trigger grid h-[66px] w-full grid-cols-[1fr_120px_1fr] items-center px-[27px] text-left text-[12px] text-[#272727] transition-colors duration-300 hover:bg-[#e8ccd8] hover:text-white"
                aria-expanded="false"
                data-accordion-trigger
              >
                <span>{name}</span>
                <span>{year}</span>
                <span>{type}</span>
              </button>
              <div class="accordion-panel max-h-0 overflow-hidden bg-white transition-[max-height] duration-500 ease-in-out" data-accordion-panel>
                {index === 0 ? (
                  <div class="accordion-content-shell">
                    <iframe
                      title="Кошелечек"
                      src={walletEmbedUrl}
                      class="h-[410px] w-[728px] border border-[rgba(0,0,0,0.1)]"
                      allowfullscreen
                    ></iframe>
                  </div>
                ) : index === 1 ? (
                  <div class="accordion-content-shell">
                    <iframe
                      title="Storage"
                      src={storageEmbedUrl}
                      class="h-[410px] w-[728px] border border-[rgba(0,0,0,0.1)]"
                      allowfullscreen
                    ></iframe>
                  </div>
                ) : (
                  <div class="accordion-content-shell">
                    <p class="text-[12px] text-[#6c6c6a]">Контент блока скоро добавим.</p>
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="shiftable absolute bottom-[135px] left-[227px] h-[448px] w-[784px]" data-fade data-envelope-block>
      <div class="relative h-full w-full bg-[#bfc0c3] shadow-[0_10px_10px_rgba(0,0,0,0.25)] [perspective:1200px]">
        <img src={envelopeBase.src} alt="" class="absolute bottom-0 left-0 h-[448px] w-[784px] object-cover" />
        <div
          class="absolute left-1/2 top-[-1px] z-20 h-[172px] w-[784px] -translate-x-1/2 bg-[#7a7a7a] opacity-100"
          style="clip-path: polygon(0 0, 100% 0, 50% 100%);"
          data-envelope-corner
        ></div>
        <div
          class="absolute left-1/2 top-0 z-[40] h-[448px] w-[784px] -translate-x-1/2"
          data-envelope-payload
        >
          <a
            href="https://t.me/skyggefox#"
            target="_blank"
            rel="noopener noreferrer"
            class="pointer-events-auto absolute left-[308px] top-[-392px] block h-[410px] w-[464px] opacity-0"
            data-envelope-item
            data-item="heart1"
            data-envelope-link
          >
            <img src={heart1Image.src} alt="Telegram @skyggefox" class="h-full w-full object-contain" />
          </a>
          <img
            src={heart3Image.src}
            alt=""
            class="pointer-events-none absolute left-[48px] top-[-372px] h-[212px] w-[240px] object-contain opacity-0"
            data-envelope-item
            data-item="heart3"
          />
          {
            contactLetters.map((letter, idx) => (
              <div
                class={`pointer-events-none absolute ${contactCirclePositions[idx]} flex h-[72px] w-[72px] items-center justify-center rounded-full bg-black opacity-0`}
                data-envelope-item
                data-item={`letter-${idx}`}
              >
                <span class="text-center text-[36px] font-medium leading-none text-white">{letter}</span>
              </div>
            ))
          }
        </div>
        <div
          class="absolute left-1/2 top-[-1px] z-30 h-[172px] w-[784px] -translate-x-1/2 bg-[#7a7a7a] opacity-100 shadow-[0_4px_8px_rgba(0,0,0,0.2)] [will-change:transform] [transform-style:preserve-3d] [backface-visibility:visible]"
          style="clip-path: polygon(0 0, 100% 0, 50% 100%);"
          data-envelope-flap-top
        ></div>
        <p class="display-font absolute bottom-[51px] left-[25px] text-[96px] leading-none text-black">
          Дл<span class="text-[48px]">я</span> теб<span class="text-[48px]">я</span>
        </p>
      </div>
    </section>

    <p class="shiftable absolute bottom-[135px] left-[1140px] text-[24px]" data-footer-sign>Skygge 2026</p>
  </div>
</main>

<script>
  import gsap from "gsap";

  const nameToggle = document.getElementById("name-toggle");

  if (nameToggle) {
    nameToggle.addEventListener("click", () => {
      const isActive = nameToggle.getAttribute("aria-pressed") === "true";
      const nextState = !isActive;

      nameToggle.setAttribute("aria-pressed", String(nextState));
      nameToggle.textContent = nextState ? "Skygge" : "Алиса Канапина";
      nameToggle.style.fontFamily = nextState ? "Montserrat, sans-serif" : "Skyggefont, Montserrat, sans-serif";
      nameToggle.style.color = nextState ? "#E8CCD8" : "#6c6c6a";
      nameToggle.style.fontWeight = nextState ? "600" : "400";
    });
  }

  const accordionItems = Array.from(document.querySelectorAll("[data-accordion-item]"));
  const graphicsSection = document.getElementById("graphics");
  const devSection = document.getElementById("dev");
  const envelopeClickZone = document.querySelector("[data-envelope-block]");
  const footerSign = document.querySelector("[data-footer-sign]");
  const graphicsAfterAccordion = document.querySelector("[data-graphics-after-accordion]");
  let activeItem = null;

  const getOpenPanelHeightByGroup = (groupName) => {
    const group = document.querySelector(`[data-accordion-group="${groupName}"]`);
    if (!group) return 0;
    const openItem = group.querySelector(".accordion-item.is-open");
    if (!openItem) return 0;
    const panel = openItem.querySelector("[data-accordion-panel]");
    return panel ? panel.scrollHeight : 0;
  };

  const setTranslateY = (element, y) => {
    if (!element) return;
    element.style.transform = `translateY(${y}px)`;
  };

  const updateAccordionLayout = () => {
    const identityOffset = getOpenPanelHeightByGroup("identity");
    const graphicsOffset = getOpenPanelHeightByGroup("graphics");
    const devOffset = getOpenPanelHeightByGroup("dev");

    setTranslateY(graphicsSection, identityOffset);
    setTranslateY(graphicsAfterAccordion, graphicsOffset);
    setTranslateY(devSection, identityOffset + graphicsOffset);
    setTranslateY(envelopeClickZone, identityOffset + graphicsOffset + devOffset);
    setTranslateY(footerSign, identityOffset + graphicsOffset + devOffset);
  };

  const closeAccordionItem = (item) => {
    const trigger = item.querySelector("[data-accordion-trigger]");
    const panel = item.querySelector("[data-accordion-panel]");
    if (!trigger || !panel) return;
    trigger.setAttribute("aria-expanded", "false");
    item.classList.remove("is-open");
    panel.style.maxHeight = "0px";
    updateAccordionLayout();
  };

  const openAccordionItem = (item) => {
    const trigger = item.querySelector("[data-accordion-trigger]");
    const panel = item.querySelector("[data-accordion-panel]");
    if (!trigger || !panel) return;

    if (activeItem && activeItem !== item) {
      closeAccordionItem(activeItem);
    }

    trigger.setAttribute("aria-expanded", "true");
    item.classList.add("is-open");
    panel.style.maxHeight = `${panel.scrollHeight}px`;
    activeItem = item;
    updateAccordionLayout();
    item.scrollIntoView({ behavior: "smooth", block: "nearest" });
  };

  accordionItems.forEach((item) => {
    const trigger = item.querySelector("[data-accordion-trigger]");
    if (!trigger) return;
    trigger.addEventListener("click", () => {
      const isOpen = item.classList.contains("is-open");
      if (isOpen) {
        closeAccordionItem(item);
        activeItem = null;
      } else {
        openAccordionItem(item);
      }
    });
  });

  window.addEventListener("resize", () => {
    if (activeItem) {
      const panel = activeItem.querySelector("[data-accordion-panel]");
      if (panel) {
        panel.style.maxHeight = `${panel.scrollHeight}px`;
      }
    }
    updateAccordionLayout();
  });

  updateAccordionLayout();

  const envelopeFlapTop = document.querySelector("[data-envelope-flap-top]");
  const envelopeItems = Array.from(document.querySelectorAll("[data-envelope-item]"));
  let envelopeStep = 0;
  let isEnvelopeAnimating = false;

  if (envelopeFlapTop) {
    gsap.set(envelopeFlapTop, {
      transformOrigin: "50% 0%",
      rotate: 0,
      rotationX: 0,
      y: 0,
      force3D: true,
    });
  }

  const getEnvelopeEnterState = (item, index) => {
    const itemKey = item.getAttribute("data-item");
    // Start all elements from the lower triangle center area.
    if (itemKey === "heart1") return { fromX: 124, fromY: 552, rotate: 16 };
    if (itemKey === "heart3") return { fromX: 344, fromY: 532, rotate: -16 };
    const letterFromX = [26, 260, 140, 62, -20, 300, -86, -200];
    const letterFromY = [322, 336, 268, 218, 258, 268, 306, 264];
    const letterRotations = {
      "letter-0": -24,
      "letter-1": 0,
      "letter-2": 0,
      "letter-3": 0,
      "letter-4": 0,
      "letter-5": -34,
      "letter-6": 26,
      "letter-7": 0,
    };
    return {
      fromX: letterFromX[index % letterFromX.length],
      fromY: letterFromY[index % letterFromY.length],
      rotate: letterRotations[itemKey] ?? 0,
    };
  };

  const applyEnvelopeHiddenState = () => {
    envelopeItems.forEach((item, index) => {
      const state = getEnvelopeEnterState(item, index);
      gsap.set(item, {
        x: state.fromX,
        y: state.fromY,
        rotate: 0,
        opacity: 0,
        transformOrigin: "50% 50%",
        force3D: true,
      });
    });
  };

  applyEnvelopeHiddenState();

  const playEnvelopeOpen = () => {
    if (!envelopeFlapTop) return Promise.resolve();
    return gsap.to(envelopeFlapTop, {
      rotationX: -172,
      y: 0,
      duration: 0.85,
      ease: "power2.inOut",
    });
  };

  const playEnvelopeItemsOut = () => {
    const tl = gsap.timeline();
    envelopeItems.forEach((item, index) => {
      const state = getEnvelopeEnterState(item, index);
      tl.to(
        item,
        {
          x: 0,
          y: 0,
          rotate: state.rotate,
          opacity: 1,
          duration: 0.8,
          ease: "power2.out",
        },
        index * 0.045,
      );
    });
    return tl;
  };

  const playEnvelopeReset = () => {
    const tl = gsap.timeline();
    envelopeItems.forEach((item, index) => {
      const state = getEnvelopeEnterState(item, index);
      tl.to(
        item,
        {
          x: state.fromX,
          y: state.fromY,
          rotate: 0,
          opacity: 0,
          duration: 0.65,
          ease: "power2.inOut",
        },
        index * 0.03,
      );
    });
    if (envelopeFlapTop) {
      tl.to(
        envelopeFlapTop,
        {
          rotationX: 0,
          y: 0,
          duration: 0.75,
          ease: "power2.inOut",
        },
        "-=0.22",
      );
    }
    return tl;
  };

  envelopeClickZone?.addEventListener("click", async (event) => {
    if (event.target instanceof Element && event.target.closest("[data-envelope-link]")) return;
    if (isEnvelopeAnimating) return;
    isEnvelopeAnimating = true;

    try {
      if (envelopeStep === 0) {
        await playEnvelopeOpen();
        envelopeStep = 1;
      } else if (envelopeStep === 1) {
        await playEnvelopeItemsOut();
        envelopeStep = 2;
      } else {
        await playEnvelopeReset();
        envelopeStep = 0;
      }
    } finally {
      isEnvelopeAnimating = false;
    }
  });
</script>
